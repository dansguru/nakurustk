{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node@2.0.0"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/api/index.ts"
    },
    {
      "src": "/api/mpesa/payment-status/(.*)",
      "dest": "/api/mpesa/payment-status.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.ts"
    }
  ]
}
